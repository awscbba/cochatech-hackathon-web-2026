---
// Announcement banner — celebration of 1100+ inscritos
// Positioned dynamically right below the navbar via JS measurement.
// Dismissible with sessionStorage persistence.
---

<!-- Spacer: reserves space so page content isn't hidden behind the fixed banner -->
<div class="banner-spacer" id="banner-spacer"></div>

<!-- The actual fixed banner -->
<div class="banner" id="announcement-banner" role="status" aria-label="Anuncio importante">
  <div class="banner-inner">
    <span class="banner-sparkle" aria-hidden="true">🚀</span>
    <p class="banner-text">
      <span class="banner-highlight">¡1,100+ inscritos!</span>
      Gracias por el increíble interés — superamos todas las expectativas.
    </p>
    <span class="banner-sparkle" aria-hidden="true">🎉</span>

    <button
      class="banner-close"
      id="banner-close-btn"
      aria-label="Cerrar anuncio"
      type="button"
    >
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <line x1="18" y1="6" x2="6" y2="18"></line>
        <line x1="6" y1="6" x2="18" y2="18"></line>
      </svg>
    </button>
  </div>

  <!-- Animated shimmer overlay -->
  <div class="banner-shimmer" aria-hidden="true"></div>
</div>

<script is:inline>
(function () {
  var banner = document.getElementById('announcement-banner');
  var spacer = document.getElementById('banner-spacer');
  var btn = document.getElementById('banner-close-btn');
  if (!banner || !btn || !spacer) return;

  // If already dismissed this session, remove both immediately
  if (sessionStorage.getItem('banner-dismissed') === '1') {
    banner.style.display = 'none';
    spacer.style.display = 'none';
    return;
  }

  // Measure the navbar height and position the banner right below it
  function positionBanner() {
    var nav = document.querySelector('.nav-sticky');
    if (!nav) return;
    var navHeight = nav.getBoundingClientRect().height;
    banner.style.top = navHeight + 'px';
  }

  positionBanner();
  window.addEventListener('resize', positionBanner);

  // Dismiss handler
  btn.addEventListener('click', function () {
    banner.style.transition = 'opacity 0.3s ease, transform 0.3s ease';
    banner.style.opacity = '0';
    banner.style.transform = 'translateY(-100%)';
    spacer.style.transition = 'height 0.3s ease';
    spacer.style.height = '0';
    sessionStorage.setItem('banner-dismissed', '1');
    setTimeout(function () {
      banner.style.display = 'none';
      spacer.style.display = 'none';
    }, 350);
  });
})();
</script>

<style>
  /* Spacer pushes content below the fixed nav + fixed banner */
  .banner-spacer {
    height: 40px;
  }

  /* Fixed banner — top is set dynamically by JS */
  .banner {
    position: fixed;
    top: 80px; /* fallback, overridden by JS */
    left: 0;
    right: 0;
    z-index: 49;
    height: 40px;
    display: flex;
    align-items: center;
    background: linear-gradient(
      90deg,
      rgba(0, 210, 255, 0.10) 0%,
      rgba(2, 11, 28, 0.95) 50%,
      rgba(0, 210, 255, 0.10) 100%
    );
    border-bottom: 1px solid rgba(0, 210, 255, 0.15);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    overflow: hidden;
  }

  .banner-inner {
    width: 100%;
    max-width: 1280px;
    margin: 0 auto;
    padding: 0 clamp(1rem, 4vw, 3rem);
    display: flex;
    align-items: center;
    justify-content: center;
    gap: var(--ds-space-3);
    position: relative;
  }

  .banner-sparkle {
    font-size: 0.85rem;
    flex-shrink: 0;
    animation: banner-bounce 2s ease-in-out infinite;
  }

  .banner-sparkle:last-child {
    animation-delay: 0.3s;
  }

  @keyframes banner-bounce {
    0%, 100% { transform: translateY(0); }
    50%      { transform: translateY(-2px); }
  }

  .banner-text {
    font-family: var(--ds-font);
    font-size: var(--ds-fs-sm);
    font-weight: 500;
    color: var(--ds-text-secondary);
    margin: 0;
    text-align: center;
    line-height: 1.3;
  }

  .banner-highlight {
    font-weight: 800;
    background: linear-gradient(90deg, var(--ds-cyan), #ffffff);
    -webkit-background-clip: text;
    background-clip: text;
    -webkit-text-fill-color: transparent;
    margin-right: var(--ds-space-1);
  }

  /* Close button */
  .banner-close {
    position: absolute;
    right: clamp(0.5rem, 2vw, 1.5rem);
    top: 50%;
    transform: translateY(-50%);
    display: grid;
    place-items: center;
    width: 24px;
    height: 24px;
    padding: 0;
    border: none;
    border-radius: var(--ds-radius-full);
    background: rgba(255, 255, 255, 0.06);
    color: var(--ds-text-muted);
    cursor: pointer;
    transition: all var(--ds-t-fast);
    flex-shrink: 0;
  }

  .banner-close:hover {
    background: rgba(255, 255, 255, 0.12);
    color: var(--ds-text-primary);
  }

  /* Shimmer sweep */
  .banner-shimmer {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      105deg,
      transparent 40%,
      rgba(0, 210, 255, 0.07) 50%,
      transparent 60%
    );
    animation: banner-shimmer 4s ease-in-out infinite;
    pointer-events: none;
  }

  @keyframes banner-shimmer {
    0%   { transform: translateX(-100%); }
    100% { transform: translateX(100%); }
  }

  @media (prefers-reduced-motion: reduce) {
    .banner-sparkle,
    .banner-shimmer {
      animation: none;
    }
  }

  @media (max-width: 768px) {
    .banner {
      height: auto;
      min-height: 48px;
      padding: var(--ds-space-2) 0;
    }

    .banner-spacer {
      height: 52px;
    }

    .banner-text {
      font-size: var(--ds-fs-sm);
    }

    .banner-sparkle:last-child {
      display: none;
    }

    .banner-inner {
      padding: 0 3.5rem 0 1.25rem;
    }
  }
</style>
