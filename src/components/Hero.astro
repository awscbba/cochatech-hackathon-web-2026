---
// Hero section with design system
---

<section id="inicio" class="hero-section">
  <!-- Background layers -->
  <div class="hero-bg-base"></div>
  <div class="hero-bg-glow"></div>

  <div class="hero-content">
    
    <!-- Left Column: Content -->
    <div class="hero-inner">
      <!-- Badge -->
      <div class="ds-badge ds-badge-outline hero-badge-custom">
        <span class="ds-badge-dot ds-badge-dot-cyan" aria-hidden="true"></span>
        Mayo 2026 · Cochabamba, Bolivia
      </div>

      <!-- Main Heading (2-3 lines, readable size, tight leading) -->
      <h1 class="hero-title">
        Cochatech, el hackathon <br/>
        más grande de <span class="ds-gradient-text ds-grad-cyan-white">Cochabamba</span>
      </h1>

      <!-- Subtitle (Bigger, readable grey) -->
      <p class="hero-subtitle">
        36 horas de pura innovación para transformar ideas audaces en soluciones reales que impacten a tu comunidad.
      </p>

      <!-- Metrics Row (Aligned perfectly below the text) -->
      <div class="ds-stat-grid hero-metrics-custom">
        <div class="ds-stat">
          <div class="ds-stat-value">+500<span class="suffix"></span></div>
          <div class="ds-stat-label">Participantes</div>
        </div>
        <div class="ds-stat">
          <div class="ds-stat-value">9</div>
          <div class="ds-stat-label">Retos Reales</div>
        </div>
       
      </div>

      <!-- CTAs (Standardized, matching primary and secondary intent) -->
      <div class="hero-actions">
        <a href="#https://script.google.com/a/macros/ucb.edu.bo/s/AKfycbxvmsLEWDDxJQaeTkhmLGeZpI6CewsnVW5IE11U4dnKS0uMUYzuU_NG9jdoktgbq2EP/exec" class="ds-btn ds-btn-primary ds-btn-lg">
          Aplicar ahora
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <line x1="5" y1="12" x2="19" y2="12"/>
            <polyline points="12 5 19 12 12 19"/>
          </svg>
        </a>
        <a href="#sobre-el-evento" class="ds-btn ds-btn-ghost ds-btn-lg">
          Explorar detalles
        </a>
      </div>
    </div>

    <!-- Right Column: Visual Element / Circuit Pattern -->
    <div class="hero-visual">
      <!-- Decorative star -->
      

      <div class="hero-circuit">
        <svg class="hero-circuit-svg" viewBox="0 0 600 600" xmlns="http://www.w3.org/2000/svg" preserveAspectRatio="xMidYMid meet">
          <!-- Abstract nodes representing connections / tech -->
          <circle cx="300" cy="300" r="140" fill="none" stroke="var(--ds-cyan)" stroke-width="1" opacity="0.2" stroke-dasharray="4 8" />
          <circle cx="300" cy="300" r="220" fill="none" stroke="var(--ds-cyan)" stroke-width="1" opacity="0.1" />
          
          <circle cx="400" cy="200" r="8" fill="var(--ds-cyan)" opacity="0.8">
            <animate attributeName="opacity" values="0.4;0.9;0.4" dur="3s" repeatCount="indefinite" />
          </circle>
          
          <circle cx="200" cy="400" r="6" fill="var(--ds-cyan)" opacity="0.6" />
          <circle cx="450" cy="450" r="5" fill="var(--ds-yellow)" opacity="0.8">
            <animate attributeName="opacity" values="0.3;1;0.3" dur="4s" repeatCount="indefinite" />
          </circle>
          
          <circle cx="150" cy="150" r="4" fill="var(--ds-cyan)" opacity="0.5" />
          <circle cx="300" cy="300" r="12" fill="var(--ds-cyan)" opacity="0.9" />

          <!-- Connection Lines -->
          <path d="M 300 300 L 400 200 L 450 450" stroke="var(--ds-cyan)" stroke-width="1.5" fill="none" opacity="0.4"/>
          <path d="M 300 300 L 200 400 L 150 150 L 400 200" stroke="var(--ds-cyan)" stroke-width="1" fill="none" opacity="0.3"/>
          <path d="M 150 150 L 300 300" stroke="var(--ds-yellow)" stroke-width="1" fill="none" opacity="0.3" stroke-dasharray="2 4" />
        </svg>
      </div>

      <div class="hero-glow-accent ds-glow-cyan"></div>
    </div>
  </div>
</section>

<style>
  .hero-section {
    position: relative;
    min-height: 100vh;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
    padding: var(--ds-space-24) 0 var(--ds-space-16);
    font-family: var(--ds-font);
  }

  .hero-bg-base {
    position: absolute;
    inset: 0;
    background: var(--ds-bg-deep);
    z-index: 0;
  }

  .hero-bg-glow {
    position: absolute;
    width: 60vw;
    height: 60vw;
    border-radius: 50%;
    background: radial-gradient(circle, var(--ds-cyan-dim) 0%, transparent 70%);
    top: -10%;
    left: -10%;
    filter: blur(100px);
    z-index: 1;
    opacity: 0.6;
    pointer-events: none;
  }

  .hero-content {
    position: relative;
    z-index: 10;
    width: 100%;
    max-width: 1280px;
    margin: 0 auto;
    padding: 0 clamp(1.5rem, 5vw, 3rem);
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--ds-space-12);
    align-items: center;
  }

  @media (min-width: 1024px) {
    .hero-content {
      grid-template-columns: 1.2fr 0.8fr; /* Balanced 2-column layout */
      gap: var(--ds-space-8);
    }
  }

  .hero-inner {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    animation: ds-fade-in-up 0.8s var(--ds-ease-out) forwards;
  }

  @keyframes ds-fade-in-up {
    from { opacity: 0; transform: translateY(30px); }
    to { opacity: 1; transform: translateY(0); }
  }

  .hero-badge-custom {
    margin-bottom: var(--ds-space-6);
    background: var(--ds-glass-bg);
    border: 1px solid rgba(0, 210, 255, 0.25);
    color: var(--ds-cyan);
    box-shadow: 0 4px 12px rgba(0, 210, 255, 0.05);
  }

  .hero-title {
    /* Adjusted size for readability, max 2-3 lines */
    font-size: clamp(2.5rem, 6vw, 4.5rem); 
    font-weight: 800;
    letter-spacing: -0.03em;
    line-height: 1.1;
    color: var(--ds-text-primary);
    margin-bottom: var(--ds-space-6);
    margin-top: 0;
    text-wrap: balance;
  }

  .hero-subtitle {
    /* Larger, brighter grey subheadline */
    font-size: clamp(1.1rem, 2vw, 1.35rem);
    font-weight: 500;
    color: var(--ds-text-secondary);
    line-height: 1.5;
    margin-bottom: var(--ds-space-10);
    margin-top: 0;
    max-width: 48ch;
    text-wrap: balance;
  }

  .hero-metrics-custom {
    margin-bottom: var(--ds-space-10);
    grid-template-columns: repeat(3, 1fr);
    width: 100%;
    max-width: 580px;
    gap: var(--ds-space-4);
  }

  .hero-metrics-custom .ds-stat {
    padding: var(--ds-space-4) var(--ds-space-5);
    background: linear-gradient(145deg, rgba(255,255,255,0.02), transparent);
    border: 1px solid var(--ds-glass-border);
  }

  .hero-metrics-custom .ds-stat-value {
    font-size: clamp(1.5rem, 3vw, 2.25rem); /* Scalable stat size */
  }

  @media (max-width: 640px) {
    .hero-metrics-custom {
      grid-template-columns: 1fr;
      max-width: 100%;
    }
  }

  .hero-actions {
    display: flex;
    flex-direction: column;
    gap: var(--ds-space-4);
    width: 100%;
  }

  @media (min-width: 480px) {
    .hero-actions {
      flex-direction: row;
      width: auto;
    }
  }

  /* --- Right Column Visuals --- */
  .hero-visual {
    position: relative;
    width: 100%;
    height: 100%;
    min-height: 400px;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  @media (max-width: 1023px) {
    .hero-visual {
      display: none; /* Hide on smaller screens to keep focus on text */
    }
  }

  .hero-circuit {
    width: 100%;
    height: 100%;
    max-width: 500px;
    max-height: 500px;
    position: relative;
    z-index: 2;
    animation: floating 6s ease-in-out infinite;
  }

  .hero-circuit-svg {
    width: 100%;
    height: 100%;
    filter: drop-shadow(0 0 15px rgba(0, 210, 255, 0.3));
  }

  @keyframes floating {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(-15px); }
  }

  .hero-glow-accent {
    position: absolute;
    width: 300px;
    height: 300px;
    border-radius: 50%;
    background: var(--ds-cyan);
    filter: blur(120px);
    opacity: 0.15;
    z-index: 1;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
  }

  .hero-star {
    position: absolute;
    top: 10%;
    right: 15%;
    font-size: 2.5rem;
    color: var(--ds-cyan);
    opacity: 0.4;
    filter: drop-shadow(0 0 15px var(--ds-cyan));
    animation: pulse-star 4s ease-in-out infinite;
    z-index: 5;
  }

  @keyframes pulse-star {
    0%, 100% { opacity: 0.3; transform: scale(1); }
    50% { opacity: 0.8; transform: scale(1.1) rotate(15deg); }
  }

  @media (max-width: 768px) {
    .hero-section {
      padding-top: var(--ds-space-24);
      min-height: auto;
      padding-bottom: var(--ds-space-16);
    }
  }
</style>
