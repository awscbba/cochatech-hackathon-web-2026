---
// Hero section — Cristo image · particle canvas · countdown
---

<section id="inicio" class="hero-section">
  <!-- Animated particle canvas -->
  <canvas class="hero-canvas" id="hero-canvas" aria-hidden="true"></canvas>

  <!-- Ambient glow -->
  <div class="hero-bg-glow" aria-hidden="true"></div>

  <div class="hero-content">

    <!-- Left Column: Content -->
    <div class="hero-inner">
      <div class="ds-badge ds-badge-outline hero-badge-custom">
        <span class="ds-badge-dot ds-badge-dot-cyan" aria-hidden="true"></span>
        Mayo 2026 · Cochabamba, Bolivia
      </div>

      <h1 class="hero-title">
        Cochatech, el hackathon <br/>
        más grande de <span class="ds-gradient-text ds-grad-cyan-white">Cochabamba</span>
      </h1>

      <p class="hero-subtitle">
        36 horas de pura innovación para transformar ideas audaces en soluciones reales que impacten a tu comunidad.
      </p>

      <!-- Stats -->
      <div class="ds-stat-grid hero-metrics-custom">
        <div class="ds-stat">
          <div class="ds-stat-value">500<span class="suffix">+</span></div>
          <div class="ds-stat-label">Participantes</div>
        </div>
        <div class="ds-stat">
          <div class="ds-stat-value">9</div>
          <div class="ds-stat-label">Retos Reales</div>
        </div>
        <div class="ds-stat">
          <div class="ds-stat-value" style="color: var(--ds-cyan);">$15k</div>
          <div class="ds-stat-label">De valor en premios</div>
        </div>
      </div>

      <!-- Countdown to May 16 2026 -->
      <div class="hero-countdown" aria-label="Cuenta regresiva al evento">
        <span class="countdown-heading">Faltan</span>
        <div class="countdown-units">
          <div class="countdown-unit">
            <span class="countdown-num" id="cd-days">--</span>
            <span class="countdown-lbl">días</span>
          </div>
          <span class="countdown-sep" aria-hidden="true">:</span>
          <div class="countdown-unit">
            <span class="countdown-num" id="cd-hours">--</span>
            <span class="countdown-lbl">hrs</span>
          </div>
          <span class="countdown-sep" aria-hidden="true">:</span>
          <div class="countdown-unit">
            <span class="countdown-num" id="cd-mins">--</span>
            <span class="countdown-lbl">min</span>
          </div>
          <span class="countdown-sep" aria-hidden="true">:</span>
          <div class="countdown-unit">
            <span class="countdown-num" id="cd-secs">--</span>
            <span class="countdown-lbl">seg</span>
          </div>
        </div>
      </div>

      <!-- CTAs -->
      <div class="hero-actions">
        <a href="#aplicar" class="ds-btn ds-btn-primary ds-btn-lg">
          Aplicar ahora
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <line x1="5" y1="12" x2="19" y2="12"/>
            <polyline points="12 5 19 12 12 19"/>
          </svg>
        </a>
        <a href="#sobre-el-evento" class="ds-btn ds-btn-ghost ds-btn-lg">
          Explorar detalles
        </a>
      </div>
    </div>

    <!-- Right Column: Cristo de la Concordia -->
    <div class="hero-visual" aria-hidden="true">
      <div class="hero-image-wrap">
        <div class="hero-image-glow"></div>
        <img
          src="/images/hero-cristo-transparent.png"
          alt="Cristo de la Concordia de Cochabamba, símbolo del hackathon"
          class="hero-cristo-img"
          loading="eager"
          decoding="async"
        />
      </div>
    </div>

  </div>
</section>

<script is:inline>
(function () {
  // ── PARTICLE CANVAS ──────────────────────────────────────────────
  var canvas = document.getElementById('hero-canvas');
  if (canvas && !window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
    var ctx = canvas.getContext('2d');
    var particles = [];
    var COUNT = 70;
    var MAX_D = 130;
    var rafId = null;
    var active = true;

    function getSection() { return canvas.closest('.hero-section'); }

    function resize() {
      var s = getSection();
      canvas.width  = s ? s.offsetWidth  : window.innerWidth;
      canvas.height = s ? s.offsetHeight : window.innerHeight;
    }

    function mkP() {
      return {
        x:  Math.random() * canvas.width,
        y:  Math.random() * canvas.height,
        vx: (Math.random() - 0.5) * 0.35,
        vy: (Math.random() - 0.5) * 0.35,
        r:  Math.random() * 1.5 + 0.5
      };
    }

    resize();
    for (var i = 0; i < COUNT; i++) particles.push(mkP());

    function tick() {
      if (!active) { rafId = null; return; }
      var w = canvas.width, h = canvas.height;
      ctx.clearRect(0, 0, w, h);
      for (var i = 0; i < particles.length; i++) {
        var p = particles[i];
        p.x = ((p.x + p.vx) + w) % w;
        p.y = ((p.y + p.vy) + h) % h;
        ctx.beginPath();
        ctx.arc(p.x, p.y, p.r, 0, 6.283);
        ctx.fillStyle = 'rgba(0,210,255,0.55)';
        ctx.fill();
        for (var j = i + 1; j < particles.length; j++) {
          var q = particles[j];
          var dx = p.x - q.x, dy = p.y - q.y;
          var d2 = dx * dx + dy * dy;
          if (d2 < MAX_D * MAX_D) {
            var alpha = 0.13 * (1 - Math.sqrt(d2) / MAX_D);
            ctx.beginPath();
            ctx.moveTo(p.x, p.y);
            ctx.lineTo(q.x, q.y);
            ctx.strokeStyle = 'rgba(0,210,255,' + alpha + ')';
            ctx.lineWidth = 0.8;
            ctx.stroke();
          }
        }
      }
      rafId = requestAnimationFrame(tick);
    }

    new IntersectionObserver(function (entries) {
      active = entries[0].isIntersecting;
      if (active && !rafId) tick();
      if (!active && rafId) { cancelAnimationFrame(rafId); rafId = null; }
    }, { threshold: 0.05 }).observe(getSection() || canvas);

    window.addEventListener('resize', function () {
      resize();
      particles = [];
      for (var i = 0; i < COUNT; i++) particles.push(mkP());
    });

    tick();
  }

  // ── COUNTDOWN ────────────────────────────────────────────────────
  // May 16 2026 00:00 Bolivia time (UTC-4)
  var target = new Date('2026-05-16T04:00:00Z').getTime();
  var elD = document.getElementById('cd-days');
  var elH = document.getElementById('cd-hours');
  var elM = document.getElementById('cd-mins');
  var elS = document.getElementById('cd-secs');

  function pad(n) { return ('0' + Math.max(0, n)).slice(-2); }

  function tick() {
    var diff = target - Date.now();
    if (diff <= 0) {
      if (elD) elD.textContent = '00';
      if (elH) elH.textContent = '00';
      if (elM) elM.textContent = '00';
      if (elS) elS.textContent = '00';
      return;
    }
    if (elD) elD.textContent = pad(Math.floor(diff / 86400000));
    if (elH) elH.textContent = pad(Math.floor((diff % 86400000) / 3600000));
    if (elM) elM.textContent = pad(Math.floor((diff % 3600000) / 60000));
    if (elS) elS.textContent = pad(Math.floor((diff % 60000) / 1000));
  }

  tick();
  setInterval(tick, 1000);
})();
</script>

<style>
  /* ── Section ─────────────────────────────────────────────────── */
  .hero-section {
    position: relative;
    min-height: 100vh;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
    padding: var(--ds-space-24) 0 var(--ds-space-16);
    font-family: var(--ds-font);
    background: var(--ds-bg-deep);
  }

  /* Particle canvas — sits above all content so particles drift over the image */
  .hero-canvas {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    z-index: 20;
    pointer-events: none;
  }

  /* Ambient glow blob */
  .hero-bg-glow {
    position: absolute;
    width: 60vw;
    height: 60vw;
    border-radius: 50%;
    background: radial-gradient(circle, var(--ds-cyan-dim) 0%, transparent 70%);
    top: -10%;
    left: -10%;
    filter: blur(100px);
    z-index: 2;
    opacity: 0.5;
    pointer-events: none;
  }

  /* ── Content grid ────────────────────────────────────────────── */
  .hero-content {
    position: relative;
    z-index: 10;
    width: 100%;
    max-width: 1280px;
    margin: 0 auto;
    padding: 0 clamp(1.5rem, 5vw, 3rem);
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--ds-space-12);
    align-items: center;
  }

  @media (min-width: 1024px) {
    .hero-content {
      grid-template-columns: 1.1fr 0.9fr;
      gap: var(--ds-space-8);
    }
  }

  /* ── Left column ─────────────────────────────────────────────── */
  .hero-inner {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    animation: ds-fade-in-up 0.8s var(--ds-ease-out) both;
  }

  @keyframes ds-fade-in-up {
    from { opacity: 0; transform: translateY(30px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  .hero-badge-custom {
    margin-bottom: var(--ds-space-6);
    background: var(--ds-glass-bg);
    border: 1px solid rgba(0, 210, 255, 0.25);
    color: var(--ds-cyan);
  }

  .hero-title {
    font-size: clamp(2.5rem, 6vw, 4.5rem);
    font-weight: 800;
    letter-spacing: -0.03em;
    line-height: 1.1;
    color: var(--ds-text-primary);
    margin: 0 0 var(--ds-space-6) 0;
    text-wrap: balance;
  }

  .hero-subtitle {
    font-size: clamp(1.05rem, 2vw, 1.3rem);
    font-weight: 400;
    color: var(--ds-text-secondary);
    line-height: 1.6;
    margin: 0 0 var(--ds-space-10) 0;
    max-width: 48ch;
    text-wrap: balance;
  }

  /* Stats row */
  .hero-metrics-custom {
    margin-bottom: var(--ds-space-8);
    grid-template-columns: repeat(3, 1fr);
    width: 100%;
    max-width: 560px;
    gap: var(--ds-space-4);
  }

  .hero-metrics-custom .ds-stat {
    padding: var(--ds-space-4) var(--ds-space-5);
    background: linear-gradient(145deg, rgba(255, 255, 255, 0.025), transparent);
    border: 1px solid var(--ds-glass-border);
  }

  .hero-metrics-custom .ds-stat-value {
    font-size: clamp(1.4rem, 3vw, 2.1rem);
  }

  @media (max-width: 480px) {
    .hero-metrics-custom {
      grid-template-columns: 1fr;
      max-width: 100%;
    }
  }

  /* ── Countdown ───────────────────────────────────────────────── */
  .hero-countdown {
    display: flex;
    align-items: center;
    gap: var(--ds-space-4);
    margin-bottom: var(--ds-space-8);
    padding: var(--ds-space-3) var(--ds-space-5);
    background: var(--ds-glass-bg);
    border: 1px solid rgba(0, 210, 255, 0.18);
    border-radius: var(--ds-radius-lg);
    width: fit-content;
    animation: ds-fade-in-up 0.8s 0.3s var(--ds-ease-out) both;
  }

  .countdown-heading {
    font-size: var(--ds-fs-xs);
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--ds-text-muted);
    white-space: nowrap;
  }

  .countdown-units {
    display: flex;
    align-items: center;
    gap: var(--ds-space-3);
  }

  .countdown-unit {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1px;
  }

  .countdown-num {
    font-size: clamp(1.2rem, 2.5vw, 1.6rem);
    font-weight: 800;
    letter-spacing: -0.02em;
    color: var(--ds-cyan);
    line-height: 1;
    font-variant-numeric: tabular-nums;
    min-width: 2ch;
    text-align: center;
  }

  .countdown-lbl {
    font-size: 0.58rem;
    color: var(--ds-text-muted);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    font-weight: 600;
  }

  .countdown-sep {
    color: var(--ds-cyan);
    font-weight: 800;
    font-size: 1.1rem;
    opacity: 0.35;
    padding-bottom: 12px;
    line-height: 1;
  }

  /* ── CTAs ────────────────────────────────────────────────────── */
  .hero-actions {
    display: flex;
    flex-direction: column;
    gap: var(--ds-space-4);
    width: 100%;
  }

  @media (min-width: 480px) {
    .hero-actions {
      flex-direction: row;
      width: auto;
    }
  }

  /* ── Right column: image ─────────────────────────────────────── */
  .hero-visual {
    position: relative;
    width: 100%;
    height: 100%;
    min-height: 420px;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  @media (max-width: 1023px) {
    .hero-visual { display: none; }
  }

  .hero-image-wrap {
    position: relative;
    z-index: 2;
    width: 100%;
    max-width: 500px;
    animation: floating 7s ease-in-out infinite;
  }

  .hero-image-glow {
    position: absolute;
    inset: -20px;
    background: radial-gradient(ellipse 70% 60% at 52% 60%, rgba(0, 210, 255, 0.18) 0%, transparent 70%);
    filter: blur(32px);
    pointer-events: none;
    z-index: 1;
    border-radius: 50%;
  }

  .hero-cristo-img {
    width: 100%;
    height: auto;
    display: block;
    position: relative;
    z-index: 2;
    filter: drop-shadow(0 24px 60px rgba(0, 210, 255, 0.2));
  }

  @keyframes floating {
    0%, 100% { transform: translateY(0); }
    50%       { transform: translateY(-14px); }
  }

  @media (max-width: 768px) {
    .hero-section {
      padding-top: var(--ds-space-24);
      min-height: auto;
      padding-bottom: var(--ds-space-16);
    }
  }
</style>
