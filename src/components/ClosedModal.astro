---
// Modal: Applications closed — shown when any "Aplicar" button is clicked
---

<div class="closed-overlay" id="closed-overlay" aria-hidden="true">
  <div class="closed-modal" role="dialog" aria-modal="true" aria-labelledby="closed-title">
    <!-- Close button -->
    <button class="closed-close" id="closed-close" aria-label="Cerrar">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <line x1="18" y1="6" x2="6" y2="18"></line>
        <line x1="6" y1="6" x2="18" y2="18"></line>
      </svg>
    </button>

    <!-- Lock icon -->
    <div class="closed-icon">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <rect x="3" y="11" width="18" height="11" rx="2" ry="2"></rect>
        <path d="M7 11V7a5 5 0 0 1 10 0v4"></path>
      </svg>
    </div>

    <!-- Content -->
    <h3 class="closed-title" id="closed-title">Inscripciones Cerradas</h3>
    <p class="closed-text">
      Las postulaciones para <strong>COCHATECH 2026</strong> se cerraron el 31 de marzo.<br />
      Gracias a todos los que aplicaron.
    </p>

    <div class="closed-divider"></div>

   

    <!-- Contact -->
    <a href="mailto:contacto@cochatech.lat" class="closed-contact">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"></path><polyline points="22,6 12,13 2,6"></polyline></svg>
      contacto@cochatech.lat
    </a>
  </div>
</div>

<script is:inline>
(function () {
  var overlay = document.getElementById('closed-overlay');
  var closeBtn = document.getElementById('closed-close');
  if (!overlay || !closeBtn) return;

  function openModal() {
    overlay.classList.add('is-open');
    overlay.setAttribute('aria-hidden', 'false');
    closeBtn.focus();
    document.body.style.overflow = 'hidden';
  }

  function closeModal() {
    overlay.classList.remove('is-open');
    overlay.setAttribute('aria-hidden', 'true');
    document.body.style.overflow = '';
  }

  // All buttons with data-closed-modal trigger the modal
  document.querySelectorAll('[data-closed-modal]').forEach(function (btn) {
    btn.addEventListener('click', function (e) {
      e.preventDefault();
      openModal();
    });
  });

  closeBtn.addEventListener('click', closeModal);

  overlay.addEventListener('click', function (e) {
    if (e.target === overlay) closeModal();
  });

  document.addEventListener('keydown', function (e) {
    if (e.key === 'Escape' && overlay.classList.contains('is-open')) closeModal();
  });
})();
</script>

<style>
  /* ── Overlay ──────────────────────────────────────────────────── */
  .closed-overlay {
    position: fixed;
    inset: 0;
    z-index: 9999;
    display: flex;
    align-items: center;
    justify-content: center;
    background: rgba(2, 11, 28, 0.0);
    backdrop-filter: blur(0px);
    -webkit-backdrop-filter: blur(0px);
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.35s var(--ds-ease-out),
                background 0.35s var(--ds-ease-out),
                backdrop-filter 0.35s var(--ds-ease-out);
    padding: var(--ds-space-4);
  }

  .closed-overlay.is-open {
    opacity: 1;
    pointer-events: auto;
    background: rgba(2, 11, 28, 0.75);
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
  }

  /* ── Modal card ───────────────────────────────────────────────── */
  .closed-modal {
    position: relative;
    max-width: 440px;
    width: 100%;
    padding: var(--ds-space-10) var(--ds-space-8);
    background: rgba(10, 22, 40, 0.92);
    border: 1px solid rgba(0, 210, 255, 0.2);
    border-radius: var(--ds-radius-xl);
    backdrop-filter: blur(24px);
    -webkit-backdrop-filter: blur(24px);
    box-shadow: 0 0 80px rgba(0, 210, 255, 0.08),
                0 24px 60px rgba(0, 0, 0, 0.5);
    text-align: center;
    transform: scale(0.92) translateY(20px);
    transition: transform 0.4s var(--ds-ease-out);
  }

  .closed-overlay.is-open .closed-modal {
    transform: scale(1) translateY(0);
  }

  /* ── Close button ─────────────────────────────────────────────── */
  .closed-close {
    position: absolute;
    top: var(--ds-space-4);
    right: var(--ds-space-4);
    width: 36px;
    height: 36px;
    border-radius: var(--ds-radius-full);
    border: 1px solid var(--ds-glass-border);
    background: var(--ds-glass-bg);
    color: var(--ds-text-secondary);
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: all var(--ds-t-fast);
    padding: 0;
  }

  .closed-close svg {
    width: 16px;
    height: 16px;
  }

  .closed-close:hover {
    color: var(--ds-text-primary);
    border-color: var(--ds-glass-border-hover);
    background: var(--ds-glass-bg-hover);
  }

  /* ── Lock icon ────────────────────────────────────────────────── */
  .closed-icon {
    width: 64px;
    height: 64px;
    margin: 0 auto var(--ds-space-6);
    border-radius: var(--ds-radius-lg);
    background: rgba(0, 210, 255, 0.08);
    border: 1px solid rgba(0, 210, 255, 0.2);
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--ds-cyan);
  }

  .closed-icon svg {
    width: 28px;
    height: 28px;
  }

  /* ── Text ─────────────────────────────────────────────────────── */
  .closed-title {
    font-size: var(--ds-fs-xl);
    font-weight: 800;
    letter-spacing: -0.02em;
    color: var(--ds-text-primary);
    margin: 0 0 var(--ds-space-3) 0;
  }

  .closed-text {
    font-size: var(--ds-fs-sm);
    color: var(--ds-text-secondary);
    line-height: 1.7;
    margin: 0;
  }

  .closed-text strong {
    color: var(--ds-cyan);
    font-weight: 700;
  }

  /* ── Divider ──────────────────────────────────────────────────── */
  .closed-divider {
    width: 60px;
    height: 1px;
    background: linear-gradient(90deg, transparent, var(--ds-cyan), transparent);
    margin: var(--ds-space-6) auto;
    opacity: 0.5;
  }

  .closed-follow {
    font-size: var(--ds-fs-xs);
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--ds-text-muted);
    margin: 0 0 var(--ds-space-5) 0;
  }

  /* ── Social links ─────────────────────────────────────────────── */
  .closed-socials {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: var(--ds-space-3);
    margin-bottom: var(--ds-space-6);
  }

  .closed-social {
    width: 44px;
    height: 44px;
    border-radius: var(--ds-radius-md);
    border: 1px solid var(--ds-glass-border);
    background: var(--ds-glass-bg);
    color: var(--ds-text-secondary);
    display: flex;
    align-items: center;
    justify-content: center;
    transition: all var(--ds-t-fast);
    text-decoration: none;
  }

  .closed-social svg {
    width: 20px;
    height: 20px;
  }

  .closed-social:hover {
    color: var(--ds-cyan);
    border-color: rgba(0, 210, 255, 0.35);
    background: rgba(0, 210, 255, 0.08);
    transform: translateY(-2px);
  }

  /* ── Contact link ─────────────────────────────────────────────── */
  .closed-contact {
    display: inline-flex;
    align-items: center;
    gap: var(--ds-space-2);
    font-size: var(--ds-fs-sm);
    font-weight: 600;
    color: var(--ds-cyan);
    text-decoration: none;
    transition: opacity var(--ds-t-fast);
  }

  .closed-contact svg {
    width: 16px;
    height: 16px;
    opacity: 0.7;
  }

  .closed-contact:hover {
    opacity: 0.75;
  }

  /* ── Mobile adjustments ───────────────────────────────────────── */
  @media (max-width: 480px) {
    .closed-modal {
      padding: var(--ds-space-8) var(--ds-space-5);
    }
  }
</style>
