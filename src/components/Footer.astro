---
// Footer component with design system
import sponsorsData from "../data/sponsors.json";
const { main, coOrganizers } = sponsorsData.organizers;
---

<footer id="contacto" class="footer-section">
  <div class="footer-container">
    <!-- Footer Grid -->
    <div class="footer-grid">
      <!-- Contact Column -->
      <div class="footer-column">
        <h3 class="footer-column-title">Contacto</h3>
        <div class="footer-contact">
          <div class="footer-contact-item">
            <p class="footer-contact-label">Email</p>
            <a href="mailto:contacto@cochatech.lat" class="footer-contact-link">
              contacto@cochatech.lat
            </a>
          </div>
          <!-- <div class="footer-contact-item">
            <p class="footer-contact-label">WhatsApp</p>
            <a href="https://wa.me/591XXXXXXXXX" class="footer-contact-link">
              +591 XX XXX XXXX
            </a>
          </div>-->
        </div>
      </div>

      <!-- Social Media Column -->
      <div class="footer-column">
        <h3 class="footer-column-title">Síguenos</h3>
        <div class="footer-social">
          <a
            href="https://instagram.com/cochatech"
            target="_blank"
            rel="noopener noreferrer"
            class="footer-social-link"
            title="Instagram"
          >
            <!-- Instagram icon -->
            <svg
              class="footer-social-svg"
              xmlns="http://www.w3.org/2000/svg"
              width="22"
              height="22"
              viewBox="0 0 24 24"
              fill="none"
              stroke-width="1.75"
              stroke-linecap="round"
              stroke-linejoin="round"
            >
              <rect width="20" height="20" x="2" y="2" rx="5" ry="5"></rect>
              <path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"></path>
              <line x1="17.5" x2="17.51" y1="6.5" y2="6.5"></line>
            </svg>
          </a>
          <a
            href="https://linkedin.com/company/cochatech"
            target="_blank"
            rel="noopener noreferrer"
            class="footer-social-link"
            title="LinkedIn"
          >
            <!-- LinkedIn icon -->
            <svg
              class="footer-social-svg"
              xmlns="http://www.w3.org/2000/svg"
              width="22"
              height="22"
              viewBox="0 0 24 24"
              fill="none"
              stroke-width="1.75"
              stroke-linecap="round"
              stroke-linejoin="round"
            >
              <path
                d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"
              ></path>
              <rect width="4" height="12" x="2" y="9"></rect>
              <circle cx="4" cy="4" r="2"></circle>
            </svg>
          </a>
          <a
            href="https://twitter.com/cochatech"
            target="_blank"
            rel="noopener noreferrer"
            class="footer-social-link"
            title="Twitter/X"
          >
            <!-- X brand logo -->
            <svg
              class="footer-social-svg"
              xmlns="http://www.w3.org/2000/svg"
              width="22"
              height="22"
              viewBox="0 0 24 24"
              fill="currentColor"
            >
              <path
                d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-4.714-6.231-5.401 6.231H2.744l7.737-8.857L1.254 2.25H8.08l4.253 5.622 5.911-5.622Zm-1.161 17.52h1.833L7.084 4.126H5.117z"
              ></path>
            </svg>
          </a>
          <a
            href="https://tiktok.com/@cochatech"
            target="_blank"
            rel="noopener noreferrer"
            class="footer-social-link"
            title="TikTok"
          >
            <!-- TikTok brand logo -->
            <svg
              class="footer-social-svg"
              xmlns="http://www.w3.org/2000/svg"
              width="22"
              height="22"
              viewBox="0 0 32 32"
              fill="currentColor"
            >
              <path
                d="M16.656 1.029c1.637-0.025 3.262-0.012 4.886-0.025 0.054 2.031 0.878 3.859 2.189 5.213l-0.002-0.002c1.411 1.271 3.247 2.095 5.271 2.235l0.028 0.002v5.036c-1.912-0.048-3.71-0.489-5.331-1.247l0.082 0.034c-0.784-0.377-1.447-0.764-2.077-1.196l0.052 0.034c-0.012 3.649 0.012 7.298-0.025 10.934-0.103 1.853-0.719 3.543-1.707 4.954l0.020-0.031c-1.652 2.366-4.328 3.919-7.371 4.011l-0.014 0c-0.123 0.006-0.268 0.009-0.414 0.009-1.73 0-3.347-0.482-4.725-1.319l0.040 0.023c-2.508-1.509-4.238-4.091-4.558-7.094l-0.004-0.041c-0.025-0.625-0.037-1.25-0.012-1.862 0.49-4.779 4.494-8.476 9.361-8.476 0.547 0 1.083 0.047 1.604 0.136l-0.056-0.008c0.025 1.849-0.050 3.699-0.050 5.548-0.423-0.153-0.911-0.242-1.42-0.242-1.868 0-3.457 1.194-4.045 2.861l-0.009 0.030c-0.133 0.427-0.21 0.918-0.21 1.426 0 0.206 0.013 0.41 0.037 0.61l-0.002-0.024c0.332 2.046 2.086 3.59 4.201 3.59 0.061 0 0.121-0.001 0.181-0.004l-0.009 0c1.463-0.044 2.733-0.831 3.451-1.994l0.010-0.018c0.267-0.372 0.45-0.822 0.511-1.311l0.001-0.014c0.125-2.237 0.075-4.461 0.087-6.698 0.012-5.036-0.012-10.060 0.025-15.083z"
              ></path>
            </svg>
          </a>
        </div>
      </div>

      <!-- Institutions Column -->
      <div class="footer-column">
        <h3 class="footer-column-title">Organizado por:</h3>

        <div class="footer-institutions-logos">
          <!-- Main Organizer (UCB) -->
          <a
            href={main.website}
            target="_blank"
            rel="noopener noreferrer"
            aria-label={main.name}
            class="footer-logo-main"
          >
            <img
              src={main.logoDesktop}
              alt={main.name}
              class="footer-logo-img-main"
            />
          </a>

          <!-- Co-Organizers in 2 columns -->
          <div class="footer-co-grid">
            {
              coOrganizers.map((org) => (
                <a
                  href={org.website}
                  target="_blank"
                  rel="noopener noreferrer"
                  aria-label={org.name}
                  class="footer-logo-co"
                >
                  <img
                    src={org.logo}
                    alt={org.name}
                    class="footer-logo-img-co"
                  />
                </a>
              ))
            }
          </div>
        </div>
      </div>
    </div>

    <!-- Divider -->
    <div class="footer-divider">
      <!-- Copyright -->
      <div class="footer-copyright-section">
        <p class="footer-copyright-text">
          &copy; 2026 COCHATECH. Todos los derechos reservados.
        </p>
        <!--- <div class="footer-legal-links">
          <a href="#" class="footer-legal-link">Privacidad</a>
          <a href="#" class="footer-legal-link">Términos</a>
          <a href="#" class="footer-legal-link">Código de Conducta</a>
        </div>-->
      </div>
    </div>

    <!-- Back to Top Button -->
    <div class="footer-back-to-top-wrapper">
      <a href="#inicio" class="footer-back-to-top"> ↑ Volver al inicio </a>
    </div>
  </div>
</footer>

<style>
  :root {
    --ds-bg-deep: #020b1c;
    --ds-bg-dark-overlay: rgba(0, 0, 0, 0.5);
    --ds-text-primary: #ffffff;
    --ds-text-secondary: rgba(255, 255, 255, 0.6);
    --ds-text-muted: rgba(255, 255, 255, 0.35);
    --ds-cyan: #00d2ff;
    --ds-cyan-dim: rgba(0, 210, 255, 0.15);
    --ds-cyan-border: rgba(0, 210, 255, 0.2);
    --ds-glass-bg: rgba(255, 255, 255, 0.03);
    --ds-glass-border: rgba(255, 255, 255, 0.07);
    --ds-font: "Inter", system-ui, -apple-system, sans-serif;
    --ds-fs-xs: clamp(0.65rem, 0.5vw + 0.4rem, 0.75rem);
    --ds-fs-sm: clamp(0.8rem, 0.6vw + 0.5rem, 0.875rem);
    --ds-fs-base: clamp(0.95rem, 0.8vw + 0.5rem, 1.0625rem);
    --ds-fs-lg: clamp(1.15rem, 1.2vw + 0.6rem, 1.35rem);
    --ds-radius-full: 9999px;
    --ds-radius-lg: 16px;
    --ds-space-2: 0.5rem;
    --ds-space-3: 0.75rem;
    --ds-space-4: 1rem;
    --ds-space-6: 1.5rem;
    --ds-space-8: 2rem;
    --ds-space-12: 3rem;
    --ds-space-16: 4rem;
    --ds-t-normal: 300ms cubic-bezier(0.16, 1, 0.3, 1);
  }

  .footer-section {
    padding: var(--ds-space-16) clamp(1rem, 4vw, 3rem);
    background: #000000;
    border-top: 1px solid var(--ds-cyan-border);
    font-family: var(--ds-font);
  }

  .footer-container {
    max-width: 1280px;
    margin: 0 auto;
  }

  /* Footer Grid */
  .footer-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
    gap: var(--ds-space-12);
    margin-bottom: var(--ds-space-12);
  }

  @media (max-width: 768px) {
    .footer-grid {
      grid-template-columns: 1fr;
      gap: var(--ds-space-8);
    }
  }

  /* Column Styling */
  .footer-column {
    display: flex;
    flex-direction: column;
  }

  .footer-column-title {
    font-size: var(--ds-fs-lg);
    font-weight: 700;
    color: var(--ds-text-primary);
    margin-bottom: var(--ds-space-6);
    margin-top: 0;
    letter-spacing: -0.01em;
  }

  /* Contact Column */
  .footer-contact {
    display: flex;
    flex-direction: column;
    gap: var(--ds-space-4);
  }

  .footer-contact-item {
    display: flex;
    flex-direction: column;
    gap: var(--ds-space-2);
  }

  .footer-contact-label {
    font-size: var(--ds-fs-xs);
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--ds-text-secondary);
    margin: 0;
  }

  .footer-contact-link {
    font-size: var(--ds-fs-base);
    color: var(--ds-cyan);
    transition: color var(--ds-t-normal);
    text-decoration: none;
  }

  .footer-contact-link:hover {
    color: var(--ds-text-primary);
  }

  /* Social Media Column */
  .footer-social {
    display: flex;
    gap: var(--ds-space-6);
    flex-wrap: wrap;
  }

  .footer-social-link {
    color: var(--ds-text-secondary);
    transition: color var(--ds-t-normal);
    text-decoration: none;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .footer-social-link:hover {
    color: var(--ds-cyan);
  }

  .footer-social-svg {
    stroke: currentColor;
  }

  /* Institutions Column */
  .footer-institutions {
    display: flex;
    flex-wrap: wrap;
    gap: var(--ds-space-3);
  }

  .footer-institution-badge {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: var(--ds-space-3) var(--ds-space-6);
    background: var(--ds-glass-bg);
    border-radius: var(--ds-radius-full);
    font-size: var(--ds-fs-sm);
    color: var(--ds-text-secondary);
    font-weight: 500;
  }

  /* Divider Section */
  .footer-divider {
    border-top: 1px solid var(--ds-cyan-border);
    padding-top: var(--ds-space-8);
    margin-bottom: var(--ds-space-8);
  }

  .footer-copyright-section {
    display: flex;
    flex-direction: column;
    gap: var(--ds-space-6);
    align-items: center;
    justify-content: space-between;
  }

  @media (min-width: 768px) {
    .footer-copyright-section {
      flex-direction: row;
    }
  }

  .footer-copyright-text {
    font-size: var(--ds-fs-sm);
    color: var(--ds-text-muted);
    margin: 0;
  }

  .footer-legal-links {
    display: flex;
    gap: var(--ds-space-6);
    flex-wrap: wrap;
    justify-content: center;
  }

  .footer-legal-link {
    font-size: var(--ds-fs-sm);
    color: var(--ds-text-muted);
    transition: color var(--ds-t-normal);
    text-decoration: none;
  }

  .footer-legal-link:hover {
    color: var(--ds-cyan);
  }

  /* Back to Top Button */
  .footer-back-to-top-wrapper {
    display: flex;
    justify-content: center;
    margin-top: var(--ds-space-8);
  }

  .footer-back-to-top {
    display: inline-block;
    padding: var(--ds-space-2) var(--ds-space-6);
    border: 1px solid var(--ds-cyan-dim);
    border-radius: var(--ds-radius-lg);
    color: var(--ds-cyan);
    font-size: var(--ds-fs-sm);
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    transition: all var(--ds-t-normal);
    text-decoration: none;
  }

  .footer-back-to-top:hover {
    border-color: var(--ds-cyan);
    background: var(--ds-cyan-dim);
  }

  /* Footer organizers section */
.footer-institutions-logos {
  display: flex;
  flex-direction: column;
  gap: var(--ds-space-6);
}

/* Main organizer */
.footer-logo-main {
  display: flex;
  justify-content: center;
  padding: var(--ds-space-2);
}

.footer-logo-img-main {
  height: 48px;      /* ⬆️ Bigger main organizer */
  width: auto;
  object-fit: contain;
  opacity: 0.92;
  transition: opacity 0.2s ease;
}

.footer-logo-img-main:hover {
  opacity: 1;
}

/* Co-organizers grid */
.footer-co-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: var(--ds-space-6); /* more breathing room */
}

.footer-logo-co {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: var(--ds-space-3);
}

.footer-logo-img-co {
  height: 66px;   /* ⬆️ bigger secondary logos */
  width: auto;
  object-fit: contain;
  opacity: 0.88;
  transition: opacity 0.2s ease;
}

.footer-logo-img-co:hover {
  opacity: 1;
}

/* Mobile tweaks */
@media (max-width: 480px) {
  .footer-logo-img-main {
    height: 42px;
  }
  .footer-logo-img-co {
    height: 42px;
  }
}
</style>
